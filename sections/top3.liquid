<div class="top3-wrapper" style="background-color: {{ section.settings.bg_color }}; padding: 30px 0;">
  <section class="top3 page-width">
    {% if section.settings.title != blank %}
      <h2>{{ section.settings.title }}</h2>
    {% endif %}

    <div class="top3__grid">
      {% for block in section.blocks %}
        <div class="top3__item" {{ block.shopify_attributes }}>
          {% if block.settings.heading != blank %}
            <h3>{{ block.settings.heading }}</h3>
          {% endif %}

          {% if block.settings.text != blank %}
            <p>{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </section>
</div>

{% comment %} CREAMOS EL SCHEMA DE NUESTRA SECTION {% endcomment %}

{% schema %}
{
  "name": "PP9 Bloques de prueba",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "TOP 3",
      "default": "Mi primera sección con bloques"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo de la sección",
      "default": "#f5f5f5"
    }
  ],
  "blocks": [
    {
      "type": "info_block",
      "name": "Bloque de información",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título del bloque",
          "default": "Título del bloque"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Texto del bloque",
          "default": "Este es un texto de prueba para entender cómo funcionan los blocks."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "top3",
      "blocks": [
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        },
        {
          "type": "info_block"
        }
      ]
    }
  ]
}
{% endschema %}
